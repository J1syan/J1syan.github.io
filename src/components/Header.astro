---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="site-title" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog/">文章</HeaderLink>
			<HeaderLink href="/categories/">分类</HeaderLink>
			<HeaderLink href="/tags/">标签</HeaderLink>
			<HeaderLink href="/about/">关于</HeaderLink>
		</div>
		<a class="github-link" href="https://github.com/J1syan" target="_blank" rel="noreferrer">GitHub</a>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid rgb(var(--gray-light));
		background: rgba(var(--background), 0.92);
		backdrop-filter: blur(12px);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(1080px, calc(100% - 2rem));
		margin: 0 auto;
		min-height: 64px;
	}

	.site-title {
		flex: 0 0 auto;
		color: rgb(var(--black));
		font-size: 1rem;
		font-weight: 700;
		text-decoration: none;
	}

	.internal-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
		flex-wrap: wrap;
	}

	nav a {
		padding: 0.5rem 0.65rem;
		color: rgb(var(--gray-dark));
		border-radius: 8px;
		text-decoration: none;
	}

	nav a:hover,
	nav a.active {
		color: rgb(var(--accent));
		background: rgba(var(--accent), 0.08);
	}

	.github-link {
		flex: 0 0 auto;
		font-size: 0.9rem;
	}

	@media (max-width: 720px) {
		nav {
			align-items: flex-start;
			flex-direction: column;
			gap: 0.35rem;
			padding: 0.8rem 0;
		}

		.internal-links {
			justify-content: flex-start;
		}

		.github-link {
			display: none;
		}
	}
</style>
