---
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';

const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} {SITE_AUTHOR}. {SITE_DESCRIPTION}</p>
	<div class="footer-links">
		<a href="/rss.xml">RSS</a>
		<a href="https://github.com/J1syan/J1syan.github.io" target="_blank" rel="noreferrer">GitHub 仓库</a>
	</div>
</footer>

<style>
	footer {
		width: min(1080px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 3rem 0 4rem;
		border-top: 1px solid rgb(var(--gray-light));
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}

	footer p {
		margin: 0;
	}

	.footer-links {
		display: flex;
		gap: 1rem;
		margin-top: 0.5rem;
	}
</style>
