---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryUrl, tagUrl } from '../lib/blog';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main class="post-page">
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<img src={heroImage.src} width={heroImage.width} height={heroImage.height} alt="" />
						</div>
					)
				}
				<header class="post-header">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						<span>·</span>
						<a href={categoryUrl(category)}>{category}</a>
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{
						updatedDate && (
							<p class="updated-date">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
					{
						tags.length > 0 && (
							<div class="tag-list">
								{tags.map((tag) => (
									<a href={tagUrl(tag)}>#{tag}</a>
								))}
							</div>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<script is:inline type="module">
			(async () => {
				const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
				if (blocks.length === 0) return;

				const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

				mermaid.initialize({
					startOnLoad: false,
					theme: 'default',
					securityLevel: 'loose',
					fontFamily: 'inherit',
				});

				for (const pre of blocks) {
					// Shiki 会把每行包裹在 <span class="line"> 中
					// 直接从 line spans 提取文本，避免 textContent 带来的额外换行
					const lines = pre.querySelectorAll('span.line');
					let graphDef;
					if (lines.length > 0) {
						graphDef = Array.from(lines)
							.map(line => line.textContent)
							.join('\n')
							.trim();
					} else {
						graphDef = pre.textContent.trim();
					}

					const id = 'mermaid-' + Math.random().toString(36).substring(2, 9);

					try {
						const { svg } = await mermaid.render(id, graphDef);
						const wrapper = document.createElement('div');
						wrapper.className = 'mermaid';
						wrapper.innerHTML = svg;
						pre.replaceWith(wrapper);
					} catch (err) {
						console.error('Mermaid render error:', err);
						// 渲染失败时保留原始代码块并显示错误提示
						const errorDiv = document.createElement('div');
						errorDiv.style.cssText = 'color: #ef4444; padding: 1rem; background: #fef2f2; border-radius: 6px; margin: 1rem 0;';
						errorDiv.innerHTML = `<strong>Mermaid 渲染失败：</strong><pre style="margin-top: 0.5rem; font-size: 0.85rem; overflow-x: auto;">${err.message}</pre>`;
						pre.parentNode.insertBefore(errorDiv, pre);
					}
				}
			})();
		</script>
	</body>
</html>

<style>
	.post-page {
		width: min(860px, calc(100% - 2rem));
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.post-header {
		margin-bottom: 2.5rem;
	}

	.post-header h1 {
		margin: 0.5rem 0 0.75rem;
	}

	.post-header p {
		max-width: 720px;
		margin: 0 0 1rem;
		color: rgb(var(--gray));
	}

	.post-meta,
	.updated-date {
		display: flex;
		gap: 0.45rem;
		align-items: center;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	#password-gate {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem;
		text-align: center;
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		margin-top: 2rem;
	}

	#password-gate .lock-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	#password-gate h3 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
	}

	#password-gate p {
		margin: 0 0 1.5rem;
		color: rgb(var(--gray));
	}

	#password-gate form {
		display: flex;
		gap: 0.5rem;
		width: 100%;
		max-width: 400px;
	}

	#password-gate input {
		flex: 1;
		padding: 0.6rem 1rem;
		border: 1px solid var(--border-color);
		border-radius: 6px;
		background: var(--input-bg);
		color: var(--text-color);
		font-size: 0.95rem;
		outline: none;
		transition: border-color 0.2s;
	}

	#password-gate input:focus {
		border-color: var(--accent-color);
	}

	#password-gate input.error {
		border-color: #ef4444;
	}

	#password-gate button {
		padding: 0.6rem 1.5rem;
		border: none;
		border-radius: 6px;
		background: var(--accent-color);
		color: white;
		font-size: 0.95rem;
		cursor: pointer;
		transition: opacity 0.2s;
	}

	#password-gate button:hover {
		opacity: 0.85;
	}

	#password-gate .error {
		color: #ef4444;
		font-size: 0.85rem;
	}

	.prose .mermaid {
		display: flex;
		justify-content: center;
		margin: 1.5rem 0;
		overflow-x: auto;
	}

	.prose pre[data-language="mermaid"] {
		background: transparent !important;
		padding: 0;
		border-radius: 0;
		overflow: visible;
	}
</style>
