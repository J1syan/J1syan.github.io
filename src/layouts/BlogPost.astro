---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryUrl, tagUrl } from '../lib/blog';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main class="post-page">
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<img src={heroImage.src} width={heroImage.width} height={heroImage.height} alt="" />
						</div>
					)
				}
				<header class="post-header">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						<span>·</span>
						<a href={categoryUrl(category)}>{category}</a>
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{
						updatedDate && (
							<p class="updated-date">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
					{
						tags.length > 0 && (
							<div class="tag-list">
								{tags.map((tag) => (
									<a href={tagUrl(tag)}>#{tag}</a>
								))}
							</div>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-page {
		width: min(860px, calc(100% - 2rem));
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.post-header {
		margin-bottom: 2.5rem;
	}

	.post-header h1 {
		margin: 0.5rem 0 0.75rem;
	}

	.post-header p {
		max-width: 720px;
		margin: 0 0 1rem;
		color: rgb(var(--gray));
	}

	.post-meta,
	.updated-date {
		display: flex;
		gap: 0.45rem;
		align-items: center;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
</style>
