---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { categoryUrl, tagUrl } from '../lib/blog';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, category, tags, heroImage } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
	</head>

	<body>
		<Header />
		<main class="post-page">
			<article>
				{
					heroImage && (
						<div class="hero-image">
							<img src={heroImage.src} width={heroImage.width} height={heroImage.height} alt="" />
						</div>
					)
				}
				<header class="post-header">
					<div class="post-meta">
						<FormattedDate date={pubDate} />
						<span>·</span>
						<a href={categoryUrl(category)}>{category}</a>
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{
						updatedDate && (
							<p class="updated-date">
								更新于 <FormattedDate date={updatedDate} />
							</p>
						)
					}
					{
						tags.length > 0 && (
							<div class="tag-list">
								{tags.map((tag) => (
									<a href={tagUrl(tag)}>#{tag}</a>
								))}
							</div>
						)
					}
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import { initMasteryTracker } from '../scripts/mastery-tracker';
			document.addEventListener('DOMContentLoaded', () => initMasteryTracker());
		</script>
	</body>
</html>

<style>
	.post-page {
		width: min(860px, calc(100% - 2rem));
	}

	.hero-image {
		margin-bottom: 2rem;
	}

	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}

	.post-header {
		margin-bottom: 2.5rem;
	}

	.post-header h1 {
		margin: 0.5rem 0 0.75rem;
	}

	.post-header p {
		max-width: 720px;
		margin: 0 0 1rem;
		color: rgb(var(--gray));
	}

	.post-meta,
	.updated-date {
		display: flex;
		gap: 0.45rem;
		align-items: center;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}

	#password-gate {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 4rem 2rem;
		text-align: center;
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 12px;
		margin-top: 2rem;
	}

	#password-gate .lock-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	#password-gate h3 {
		margin: 0 0 0.5rem;
		font-size: 1.25rem;
	}

	#password-gate p {
		margin: 0 0 1.5rem;
		color: rgb(var(--gray));
	}

	#password-gate form {
		display: flex;
		gap: 0.5rem;
		width: 100%;
		max-width: 400px;
	}

	#password-gate input {
		flex: 1;
		padding: 0.6rem 1rem;
		border: 1px solid var(--border-color);
		border-radius: 6px;
		background: var(--input-bg);
		color: var(--text-color);
		font-size: 0.95rem;
		outline: none;
		transition: border-color 0.2s;
	}

	#password-gate input:focus {
		border-color: var(--accent-color);
	}

	#password-gate input.error {
		border-color: #ef4444;
	}

	#password-gate button {
		padding: 0.6rem 1.5rem;
		border: none;
		border-radius: 6px;
		background: var(--accent-color);
		color: white;
		font-size: 0.95rem;
		cursor: pointer;
		transition: opacity 0.2s;
	}

	#password-gate button:hover {
		opacity: 0.85;
	}

	#password-gate .error {
		color: #ef4444;
		font-size: 0.85rem;
	}

	.prose .mermaid {
		display: flex;
		justify-content: center;
		margin: 1.5rem 0;
		overflow-x: auto;
	}

	.prose pre[data-language="mermaid"] {
		background: transparent !important;
		padding: 0;
		border-radius: 0;
		overflow: visible;
	}
</style>

<!-- Mastery Tracker 样式必须用 is:global，因为 DOM 元素由 JS 动态创建，不含 Astro scoped 属性 -->
<style is:global>
	#mastery-toolbar {
		margin-bottom: 1.5rem;
		padding: 1rem 1.25rem;
		background: var(--card-bg);
		border: 1px solid var(--border-color);
		border-radius: 10px;
	}

	.mastery-progress {
		height: 8px;
		background: rgb(var(--gray-light) / 0.3);
		border-radius: 4px;
		overflow: hidden;
		margin-bottom: 0.6rem;
	}

	.mastery-progress-fill {
		height: 100%;
		width: 0%;
		background: rgb(var(--accent));
		border-radius: 4px;
		transition: width 0.4s ease;
	}

	.mastery-toolbar-info {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.mastery-count {
		font-size: 0.9rem;
		color: rgb(var(--gray));
		font-weight: 500;
	}

	.mastery-toggle {
		font-size: 0.85rem;
		padding: 0.3rem 0.75rem;
		border: 1px solid var(--border-color);
		border-radius: 6px;
		background: transparent;
		color: rgb(var(--gray));
		cursor: pointer;
		transition: all 0.2s;
	}

	.mastery-toggle:hover {
		border-color: rgb(var(--accent));
		color: rgb(var(--accent));
	}

	.problem-heading {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.mastery-check {
		position: relative;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 20px;
		height: 20px;
		flex-shrink: 0;
		cursor: pointer;
	}

	.mastery-check input {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	.mastery-check .checkmark {
		width: 18px;
		height: 18px;
		border: 2px solid rgb(var(--gray-light));
		border-radius: 4px;
		transition: all 0.2s;
	}

	.mastery-check input:checked + .checkmark {
		background: rgb(var(--accent));
		border-color: rgb(var(--accent));
	}

	.mastery-check input:checked + .checkmark::after {
		content: '';
		position: absolute;
		left: 5px;
		top: 2px;
		width: 5px;
		height: 9px;
		border: solid white;
		border-width: 0 2px 2px 0;
		transform: rotate(45deg);
	}

	.mastery-check:hover .checkmark {
		border-color: rgb(var(--accent));
	}

	.problem-heading.mastered .problem-title {
		text-decoration: line-through;
		color: rgb(var(--gray));
		opacity: 0.7;
	}

	.problem-section.mastered {
		opacity: 0.5;
		transition: opacity 0.3s;
	}

	.problem-section.mastered:hover {
		opacity: 0.85;
	}

	.prose.hide-mastered .problem-section.mastered {
		display: none;
	}
</style>
