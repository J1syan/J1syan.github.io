---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';
import {
	categoryUrl,
	getPostsByTag,
	getPublishedPosts,
	getTags,
	postUrl,
} from '../../lib/blog';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return getTags(posts).map((tag) => ({
		params: { tag: tag.name },
		props: { tag: tag.name },
	}));
}

const { tag } = Astro.props as { tag: string };
const posts = getPostsByTag(await getPublishedPosts(), tag);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`标签：${tag}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="eyebrow">Tag</p>
				<h1>#{tag}</h1>
				<p>当前标签下共有 {posts.length} 篇文章。</p>
			</header>

			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={postUrl(post)}>
								<div>
									<h2>{post.data.title}</h2>
									<p>{post.data.description}</p>
									<div class="post-taxonomy">
										<span>{post.data.category}</span>
									</div>
								</div>
								<span>
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ul>
			<div class="shortcut-links">
				<a href="/tags/">全部标签</a>
				{posts.map((post) => <a href={categoryUrl(post.data.category)}>{post.data.category}</a>)}
			</div>
		</main>
		<Footer />
	</body>
</html>
