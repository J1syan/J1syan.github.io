---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="关于" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="eyebrow">About</p>
				<h1>关于 {SITE_AUTHOR}</h1>
				<p>{SITE_DESCRIPTION}。这个页面可以继续补充你的个人介绍、技术方向、联系方式和项目经历。</p>
			</header>

			<div class="prose">
				<h2>我会写什么</h2>
				<p>这个博客用于沉淀学习过程和生活记录。你可以把它当作长期笔记库，也可以逐步整理成公开的技术文章。</p>

				<h2>联系方式</h2>
				<p>
					GitHub:
					<a href="https://github.com/J1syan" target="_blank" rel="noreferrer">github.com/J1syan</a>
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
