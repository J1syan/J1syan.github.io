---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { categoryUrl, getCategories, getPublishedPosts, getTags, postUrl, tagUrl } from '../lib/blog';

const posts = await getPublishedPosts();
const recentPosts = posts.slice(0, 5);
const categories = getCategories(posts);
const tags = getTags(posts);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">J1syan 的个人博客</p>
				<h1>{SITE_TITLE}</h1>
				<p>{SITE_DESCRIPTION}。这里会记录技术学习、项目实践、读书笔记和日常观察。</p>
				<div class="actions">
					<a class="button" href="/blog/">阅读文章</a>
					<a href="/rss.xml">订阅 RSS</a>
				</div>
			</section>

			<section class="section-block">
				<div class="section-header">
					<h2>最新文章</h2>
					<a href="/blog/">全部文章</a>
				</div>
				<ul class="post-list">
					{
						recentPosts.map((post) => (
							<li>
								<a href={postUrl(post)}>
									<div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
									</div>
									<span>
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
			</section>

			<section class="overview-grid">
				<div>
					<div class="section-header">
						<h2>分类</h2>
						<a href="/categories/">查看</a>
					</div>
					<div class="pill-list">
						{categories.map((category) => <a href={categoryUrl(category.name)}>{category.name} ({category.count})</a>)}
					</div>
				</div>
				<div>
					<div class="section-header">
						<h2>标签</h2>
						<a href="/tags/">查看</a>
					</div>
					<div class="pill-list">
						{tags.map((tag) => <a href={tagUrl(tag.name)}>{tag.name} ({tag.count})</a>)}
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
