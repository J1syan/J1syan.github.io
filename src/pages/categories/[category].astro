---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';
import {
	getCategories,
	getPostsByCategory,
	getPublishedPosts,
	postUrl,
	tagUrl,
} from '../../lib/blog';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	return getCategories(posts).map((category) => ({
		params: { category: category.name },
		props: { category: category.name },
	}));
}

const { category } = Astro.props as { category: string };
const posts = getPostsByCategory(await getPublishedPosts(), category);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`分类：${category}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="eyebrow">Category</p>
				<h1>{category}</h1>
				<p>当前分类下共有 {posts.length} 篇文章。</p>
			</header>

			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={postUrl(post)}>
								<div>
									<h2>{post.data.title}</h2>
									<p>{post.data.description}</p>
									<div class="post-taxonomy">
										{post.data.tags.map((tag) => (
											<span>#{tag}</span>
										))}
									</div>
								</div>
								<span>
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ul>
			<div class="shortcut-links">
				<a href="/categories/">全部分类</a>
				{posts.flatMap((post) => post.data.tags).slice(0, 6).map((tag) => <a href={tagUrl(tag)}>#{tag}</a>)}
			</div>
		</main>
		<Footer />
	</body>
</html>
