---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { categoryUrl, getPublishedPosts, postUrl, tagUrl } from '../../lib/blog';

const posts = await getPublishedPosts();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="全部文章" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<p class="eyebrow">{SITE_TITLE}</p>
				<h1>全部文章</h1>
				<p>按发布时间倒序整理所有已发布文章。</p>
			</header>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={postUrl(post)}>
								<div>
									<h2>
										{post.data.title}
										{post.data.password && <span class="lock-badge" title="加密文章">&#128274;</span>}
									</h2>
									<p>{post.data.description}</p>
									<div class="post-taxonomy">
										<span>{post.data.category}</span>
										{post.data.tags.map((tag) => <span>#{tag}</span>)}
									</div>
								</div>
								<span>
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						</li>
					))
				}
			</ul>
			<div class="shortcut-links">
				<a href="/categories/">按分类浏览</a>
				<a href="/tags/">按标签浏览</a>
				<a href={categoryUrl('学习笔记')}>学习笔记</a>
				<a href={tagUrl('生活')}>生活</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
